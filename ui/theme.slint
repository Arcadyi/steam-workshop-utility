import "../../resources/fonts/DM_Sans/DMSans-VariableFont_opsz,wght.ttf";
export global Theme {

    // Mode
    in-out property <bool> dark-mode: false;

    // Backgrounds / Surfaces
    out property <brush> background: dark-mode ? #1C1F21: #DBDBDB;
    out property <brush> surface: dark-mode ?
        @linear-gradient(40deg, #141617 0%, #1C1F21 100%) : #F2F2F2;
    out property <brush> shadow: dark-mode ? #090A0B : #090A0B;

    // Buttons
    out property <brush> button: background;
    out property <brush> button-secondary: gradient-vertical;
    out property <brush> button-tertiary:
        @linear-gradient(60deg, #561D25 0%, #CE8147 100%);
    out property <brush> button-quarternary: dark-mode ?
        @linear-gradient(60deg, #A52B3B 0%, #E37826 100%):
        button-secondary;
    // Borders
    //out property <brush> border-light: dark-mode ? #858585 : #FFFFFF;
    out property <brush> border-light: dark-mode ?
         @linear-gradient(0deg, #525252 0%, #858585 100%):
         @linear-gradient(0deg, #C4C4C4 0%, #FFFFFF 100%);
    out property <brush> border-selected: dark-mode ? #FF7D00 : border-light;
    out property <brush> border-gray: dark-mode ? #525252 : #C4C4C4;
    out property <length> border-thin: 1px;
    out property <length> border-normal: 2px;
    out property <length> border-medium: 4px;
    out property <length> border-thick: 6px;

    // Text
    out property <brush> text-primary: dark-mode ? #FFFFFF: #141617;
    out property <brush> text-secondary: dark-mode ? #8F8F8F : #292929;
    out property <brush> text-muted: dark-mode ? #474747 : #A3A3A3;
    out property <brush> text-inverse: background;

    // Accent / Brand
    out property <brush> primary: dark-mode ? #8F8F8F: #1F1F1F;
    out property <brush> secondary: dark-mode ? #CCCCCC: #3D3D3D;
    out property <brush> accent: dark-mode ? #2AB0D5: #2AB0D5;

    out property <brush> gradient-horizontal:
        dark-mode ?
            @linear-gradient(50deg, primary 0%, secondary 100%) :
            @linear-gradient(50deg, primary 0%, secondary 100%);

    out property <brush> gradient-vertical-fade-top:
        dark-mode ?
            @linear-gradient(0deg, shadow.transparentize(0.4) 0%,shadow.transparentize(1.0) 10% , shadow.transparentize(1.0) 100%):
            @linear-gradient(0deg, shadow.transparentize(0.4) 0%,shadow.transparentize(1.0) 10% , shadow.transparentize(1.0) 100%);

    out property <brush> gradient-vertical-fade-bottom:
        dark-mode ?
            @linear-gradient(0deg, shadow.transparentize(1.0) 0%, shadow.transparentize(1.0) 90%, shadow.transparentize(0.4) 100%):
            @linear-gradient(0deg, shadow.transparentize(1.0) 0%, shadow.transparentize(1.0) 90%, shadow.transparentize(0.4) 100%);

    out property <brush> gradient-horizontal-color:
        dark-mode ?
            @linear-gradient(60deg, #561D25 0%, #CE8147 100%) :
            @linear-gradient(60deg, #561D25 0%, #CE8147 100%);

    out property <brush> gradient-vertical:
        dark-mode ?
            @linear-gradient(0deg, primary 0%, secondary 100%) :
            @linear-gradient(0deg, primary 0%, secondary 100%);


    out property <brush> gradient-background-horizontal:
        dark-mode ?
            @linear-gradient(50deg, surface 0,  background 100%) :
            @linear-gradient(50deg, surface 0,  background 100%);

    out property <brush> gradient-background-vertical:
        dark-mode ?
            @linear-gradient(0deg, surface 0,  background 100%) :
            @linear-gradient(0deg, surface 0,  background 100%);

    // Status brushs
    out property <brush> success:
        dark-mode ?
            @linear-gradient(0deg, #49B12F 0%, #38C813 100%) :
            @linear-gradient(0deg, #2F711E 0%, #49B12F 100%);
    out property <brush> warning: dark-mode ? #FF7F1F : #FF7F1F;
    out property <brush> danger:
        dark-mode ?
            @linear-gradient(0deg, #A41111 0%, #A41111 100%) :
            @linear-gradient(0deg, #971313 0%, #C81919 100%);
    out property <brush> danger-hover: dark-mode ? #FC4949 : #FC4949;

    // Typography
    out property <length> font-display: 34px;
    out property <length> font-title: 28px;
    out property <length> font-heading: 22px;
    out property <length> font-subheading: 18px;
    out property <length> font-body: 15px;
    out property <length> font-small: 13px;
    out property <length> font-tiny: 11px;

    // Fonts
    out property <string> font-family: "DM Sans";

    // Font Weights
    out property <int> weight-thin: 200;
    out property <int> weight-normal: 400;
    out property <int> weight-medium: 500;
    out property <int> weight-semibold: 600;
    out property <int> weight-bold: 700;

    // Spacing
    out property <length> spacing-xxxxs: 1px;
    out property <length> spacing-xxxs: 2px;
    out property <length> spacing-xxs: 4px;
    out property <length> spacing-xs: 8px;
    out property <length> spacing-sm: 12px;
    out property <length> spacing-md: 16px;
    out property <length> spacing-lg: 24px;
    out property <length> spacing-xl: 32px;
    out property <length> spacing-xxl: 48px;

    // Radius
    out property <length> radius-xxs: 4px;
    out property <length> radius-xs: 8px;
    out property <length> radius-sm: 12px;
    out property <length> radius-md: 16px;
    out property <length> radius-lg: 22px;
    out property <length> radius-xl: 999px;

    // Component Sizes
    out property <length> topbar-height: 64px;
    out property <length> sidebar-width: 260px;
    out property <length> button-height: 44px;
    out property <length> input-height: 44px;
    out property <length> card-padding: 20px;

    // Shadows (Opacity Tokens)
    out property <length> shadow-soft: dark-mode ? 10px : 10px;
    out property <length> shadow-medium: dark-mode ? 1px : 5px;
    out property <length> shadow-strong: dark-mode ? 5px : 2px;

    // Animation
    out property <duration> animation-fast: 100ms;
    out property <duration> animation-normal: 180ms;
    out property <duration> animation-slow: 300ms;
}

export global Icon {
    out property <image> check: @image-url("../resources/icons/check.svg");
    out property <image> close: @image-url("../resources/icons/close.svg");
    out property <image> cross: @image-url("../resources/icons/cross.svg");
    out property <image> density_low: @image-url("../resources/icons/density_low.svg");
    out property <image> density_high: @image-url("../resources/icons/density_high.svg");
    out property <image> double_arrow_l: @image-url("../resources/icons/double_arrow_left.svg");
    out property <image> double_arrow_r: @image-url("../resources/icons/double_arrow_right.svg");
    out property <image> folder: @image-url("../resources/icons/folder.svg");
    out property <image> game: @image-url("../resources/icons/game.svg");
    out property <image> import_: @image-url("../resources/icons/import.svg");
    out property <image> maximize: @image-url("../resources/icons/maximize.svg");
    out property <image> minimize: @image-url("../resources/icons/minimize.svg");
    out property <image> question_mark: @image-url("../resources/icons/question_mark.svg");
    out property <image> remove: @image-url("../resources/icons/remove.svg");
    out property <image> share: @image-url("../resources/icons/share.svg");
    out property <image> steam: @image-url("../resources/icons/steam.svg");
    out property <image> steamdb: @image-url("../resources/icons/steamdb.svg");
    out property <image> search: @image-url("../resources/icons/search.svg");

    // TODO: Remove this
    out property <image> capsule_test: @image-url("../resources/test/capsule.jpg");
    out property <image> icon_test: @image-url("../resources/test/icon.jpg");
}
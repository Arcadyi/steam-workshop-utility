{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "steam-workshop-utility-tauri",
  "version": "0.1.0",
  "identifier": "com.arcady.steam-workshop-utility-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Steam Workshop Utility",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://*.steamstatic.com https://*.cloudflare.steamstatic.com https://*.akamaihd.net https://*.steam.com https://cdn.akamai.steamstatic.com https://shared.fastly.steamstatic.com data: blob: 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
